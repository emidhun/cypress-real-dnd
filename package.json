{
  "name": "cypress-real-dnd",
  "version": "0.1.3",
  "description": "Real HTML5 drag-and-drop for Cypress via Chrome DevTools Protocol. The first Cypress plugin that actually triggers react-dnd, Sortable.js, dnd-kit's html5 sensor, and plain HTML5 draggables — where cypress-drag-drop's synthetic events and cypress-real-events' mouse events do not.",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./src/index.js",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./plugin": {
      "types": "./types/plugin.d.ts",
      "require": "./src/plugin.js",
      "import": "./src/plugin.js",
      "default": "./src/plugin.js"
    },
    "./commands": {
      "types": "./types/commands.d.ts",
      "require": "./src/commands.js",
      "import": "./src/commands.js",
      "default": "./src/commands.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "echo 'See examples/ for a working react-dnd self-test'"
  },
  "keywords": [
    "cypress",
    "cypress-plugin",
    "drag",
    "drop",
    "drag-and-drop",
    "html5",
    "react-dnd",
    "cdp",
    "chrome-devtools-protocol"
  ],
  "author": "emidhun <midhun752@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emidhun/cypress-real-dnd.git"
  },
  "bugs": {
    "url": "https://github.com/emidhun/cypress-real-dnd/issues"
  },
  "homepage": "https://github.com/emidhun/cypress-real-dnd#readme",
  "peerDependencies": {
    "cypress": ">=12"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0"
  },
  "engines": {
    "node": ">=18"
  }
}
